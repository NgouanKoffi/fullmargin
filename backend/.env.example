###########################################
# Environnement & serveur (LOCAL DEV)
###########################################
NODE_ENV=development
PORT=5179
APP_NAME=FullMargin
APP_URL=http://localhost:5173
PUBLIC_WEB_BASE_URL=http://localhost:5173

###########################################
# Base de données
###########################################
MONGO_URI=

###########################################
# CORS (origines autorisées en local)
###########################################
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=0
HSTS_MAX_AGE=15552000

###########################################
# Authentification / JWT
###########################################
JWT_SECRET=
JWT_EXPIRES_IN=7d

###########################################
# Email
###########################################
BREVO_API_KEY=
MAIL_FROM=noreply@fullmargin.net

SENDGRID_API_KEY=
MAIL_FROM_NAME=FullMargin
MAIL_REPLY_TO=noreply@fullmargin.net

AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

###########################################
# Analytics
###########################################
IP_SALT=

###########################################
# Google OAuth (LOCAL)
###########################################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5179/api/auth/google/callback
FRONT_ORIGIN=http://localhost:5173

###########################################
# Stockage média
###########################################
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

STORAGE_PROVIDER=bunny
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_CDN_URL=

# GDRIVE
# GOOGLE_APPLICATION_CREDENTIALS=./credentials/fullmargin-storage-service-account.json
# GDRIVE_ROOT_FOLDER_ID=

###########################################
# IMAP (réception des réponses)
###########################################
IMAP_ACCOUNTS=noreply,podcast
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_BOX=INBOX
IMAP_POLL_MS=0
IMAP_FULL_BACKFILL=true
IMAP_DISCOVER_FOLDERS=false
IMAP_NOREPLY_EXTRA_BOXES=Sent,Drafts,Junk,Spam,Trash,Archive
IMAP_PODCAST_EXTRA_BOXES=Sent,Drafts,Junk,Spam,Trash,Archive

IMAP_NOREPLY_USER=noreply@fullmargin.net
IMAP_NOREPLY_PASS=
IMAP_PODCAST_USER=podcast@fullmargin.net
IMAP_PODCAST_PASS=

###########################################
# Paiements
###########################################
STRIPE_ENV=test
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=usd

FEDAPAY_SECRET_KEY=
FEDAPAY_BASE_URL=https://api.fedapay.com/v1
FEDAPAY_WEBHOOK_URL=

VITE_FEEXPAY_ENV=test
VITE_FEEXPAY_TOKEN_TEST=
VITE_FEEXPAY_SHOP_ID_TEST=
VITE_FEEXPAY_TOKEN_LIVE=
VITE_FEEXPAY_SHOP_ID_LIVE=

NOWPAYMENTS_ENV=sandbox
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_KEY_SANDBOX=
NOWPAYMENTS_IPN_SECRET_SANDBOX=
NOWPAYMENTS_IPN_CALLBACK_URL=
NOWPAYMENTS_SANDBOX_CASE=success

###########################################
# Fullmetrix SSO
###########################################
SSO_PARTNER_SECRET=
SSO_FULLMETRIX_CALLBACK=

###########################################
# Jitsi & Licences
###########################################
JITSI_DOMAIN=
JITSI_APP_ID=
JITSI_APP_SECRET=

SECURE_LICENSES_BASE_URL=
SECURE_LICENSES_ISSUE_API_KEY=
SECURE_LICENSES_RENEW_BEARER_TOKEN=
SECURE_LICENSES_DEBUG=1
