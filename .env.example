# Domaine public du site en dev
VITE_PUBLIC_WEB_BASE=http://localhost:5173

# Front → passe par le proxy Vite (/api → http://localhost:5179)
VITE_API_BASE=/api
VITE_API_URL=http://localhost:5179/api
VITE_UPLOADS_BASE=/uploads

# Google (tu gardes ton client id, mais le secret est dans le backend)
VITE_GOOGLE_CLIENT_ID=

# Optionnel : coupe l’analytics si user connecté
VITE_ANALYTICS_EXCLUDE_AUTHED=1

# --- STRIPE ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_ENV=test

# --- FEDAPAY ---
FEDAPAY_SECRET_KEY=
FEDAPAY_BASE_URL=https://api.fedapay.com/v1
FEDAPAY_WEBHOOK_URL=

# --- FEEXPAY FRONTEND ---
VITE_FEEXPAY_ENV=test
VITE_FEEXPAY_TOKEN_LIVE=
VITE_FEEXPAY_SHOP_ID_LIVE=
VITE_FEEXPAY_TOKEN_TEST=
VITE_FEEXPAY_SHOP_ID_TEST=

# --- SSO ---
SSO_PARTNER_SECRET=
SSO_FULLMETRIX_CALLBACK=

# --- STORAGE ---
STORAGE_PROVIDER=bunny
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_HOST=storage.bunnycdn.com
BUNNY_CDN_URL=

# --- NOWPAYMENTS ---
NOWPAYMENTS_ENV=sandbox
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_API_KEY_SANDBOX=
NOWPAYMENTS_IPN_SECRET_SANDBOX=
PUBLIC_API_BASE_URL=
PUBLIC_WEB_BASE_URL=
